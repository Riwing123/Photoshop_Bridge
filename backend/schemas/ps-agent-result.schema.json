{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.ps-agent/schemas/ps-agent-result.schema.json",
  "title": "PS Agent Job Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "ps-agent/v1"
    },
    "job_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]{1,96}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error",
        "cancelled"
      ]
    },
    "document": {
      "$ref": "#/$defs/document_state"
    },
    "state": {
      "$ref": "#/$defs/document_state"
    },
    "global_preview": {
      "$ref": "#/$defs/preview_pair"
    },
    "regions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/region_asset"
      }
    },
    "applied_ops": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error": {
      "$ref": "#/$defs/error"
    },
    "timings": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    }
  },
  "$defs": {
    "document_state": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "mode": {
          "type": "string"
        },
        "revision": {
          "type": "string"
        },
        "active_layer_id": {
          "type": [
            "integer",
            "string",
            "null"
          ]
        },
        "layers": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "image_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri",
        "mime_type"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "uri": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "mime_type": {
          "type": "string",
          "enum": [
            "image/png",
            "image/jpeg"
          ]
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "scale_factor": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "preview_pair": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "before": {
          "$ref": "#/$defs/image_asset"
        },
        "after": {
          "$ref": "#/$defs/image_asset"
        },
        "scale_factor": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "bbox": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "properties": {
        "x": {
          "type": "number",
          "minimum": 0
        },
        "y": {
          "type": "number",
          "minimum": 0
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "region_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "bbox"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        },
        "padded_bbox": {
          "$ref": "#/$defs/bbox"
        },
        "before": {
          "$ref": "#/$defs/image_asset"
        },
        "after": {
          "$ref": "#/$defs/image_asset"
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": [
            "object",
            "array",
            "string",
            "null"
          ]
        }
      }
    }
  }
}
