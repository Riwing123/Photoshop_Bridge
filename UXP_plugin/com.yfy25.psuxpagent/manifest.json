{
  "id": "com.yfy25.psuxpagent",
  "name": "PS UXP Agent",
  "version": "0.11.14",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "26.10.0"
  },
  "manifestVersion": 5,
  "requiredPermissions": {
    "network": {
      "domains": [
        "http://127.0.0.1:17860",
        "http://127.0.0.1:17860/",
        "http://127.0.0.1:17860/health",
        "http://127.0.0.1:17860/uxp/",
        "http://127.0.0.1:17860/api/",
        "http://localhost:17860",
        "http://localhost:17860/",
        "http://localhost:17860/health",
        "http://localhost:17860/uxp/",
        "http://localhost:17860/api/"
      ]
    },
    "localFileSystem": "plugin"
  },
  "entrypoints": [
    {
      "type": "command",
      "id": "refreshStatus",
      "label": "Refresh PS UXP Agent"
    },
    {
      "type": "panel",
      "id": "agentPanel",
      "minimumSize": {
        "width": 260,
        "height": 260
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 300,
        "height": 420
      },
      "preferredFloatingSize": {
        "width": 360,
        "height": 480
      },
      "icons": [
        {
          "width": 32,
          "height": 32,
          "path": "icons/dark@1x.png",
          "scale": [
            1
          ],
          "theme": [
            "dark",
            "darkest",
            "medium"
          ],
          "species": [
            "generic"
          ]
        },
        {
          "width": 32,
          "height": 32,
          "path": "icons/light@1x.png",
          "scale": [
            1
          ],
          "theme": [
            "lightest",
            "light"
          ],
          "species": [
            "generic"
          ]
        }
      ],
      "label": {
        "default": "PS UXP Agent"
      }
    }
  ],
  "icons": [
    {
      "width": 32,
      "height": 32,
      "path": "icons/dark@1x.png",
      "scale": [
        1
      ],
      "theme": [
        "darkest",
        "dark",
        "medium"
      ]
    },
    {
      "width": 32,
      "height": 32,
      "path": "icons/light@1x.png",
      "scale": [
        1
      ],
      "theme": [
        "lightest",
        "light"
      ]
    }
  ]
}
